<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Smoke suite — fast sanity check, run against every deployment.
  Usage: mvn test -Denv=staging -Dtestng.suite=testng-smoke.xml
-->
<suite name="Smoke Test Suite"
       parallel="tests"
       thread-count="2"
       verbose="1">

    <listeners>
        <listener class-name="com.framework.core.retry.RetryListener"/>
    </listeners>

    <test name="UI Smoke">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.framework.ui"/>
        </packages>
    </test>

    <test name="API Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.framework.api"/>
        </packages>
    </test>

</suite>
