<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  API-only test suite — no browser required, fast parallel execution.
  Usage: mvn test -Denv=staging -Dtestng.suite=testng-api.xml
-->
<suite name="API Test Suite"
       parallel="classes"
       thread-count="6"
       verbose="1">

    <listeners>
        <listener class-name="com.framework.core.retry.RetryListener"/>
    </listeners>

    <test name="API Tests">
        <packages>
            <package name="com.framework.api"/>
        </packages>
    </test>

</suite>
