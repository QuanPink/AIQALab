<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Full test suite — runs UI + API in parallel.
  Usage: mvn test -Denv=dev
-->
<suite name="QA Automation Framework — Full Suite"
       parallel="tests"
       thread-count="4"
       verbose="1">

    <listeners>
        <listener class-name="com.framework.core.retry.RetryListener"/>
    </listeners>

    <!-- ── UI Tests ─────────────────────────────────────────────────── -->
    <test name="UI Tests" parallel="methods" thread-count="3">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.framework.ui"/>
        </packages>
    </test>

    <!-- ── API Tests ────────────────────────────────────────────────── -->
    <test name="API Tests" parallel="classes" thread-count="6">
        <packages>
            <package name="com.framework.api"/>
        </packages>
    </test>

</suite>
