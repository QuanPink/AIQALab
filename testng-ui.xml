<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  UI-only test suite.
  Usage: mvn test -Denv=dev -Dtestng.suite=testng-ui.xml
-->
<suite name="UI Test Suite"
       parallel="methods"
       thread-count="3"
       verbose="1">

    <listeners>
        <listener class-name="com.framework.core.retry.RetryListener"/>
    </listeners>

    <test name="UI Tests — Chrome">
        <parameter name="browser" value="chrome"/>
        <packages>
            <package name="com.framework.ui"/>
        </packages>
    </test>

</suite>
